{
  "name": "worker-mcp",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "worker": "./dist/server.js",
    "worker-report": "./dist/report.js"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build --target=bun --minify --outdir=dist src/server.ts && bun build --target=bun --minify --outdir=dist src/reaper.ts && bun build --target=bun --minify --outdir=dist src/report.ts",
    "start": "bun run dist/server.js",
    "report": "bun run dist/report.js",
    "typecheck": "bunx tsgo --noEmit",
    "test": "bun test --timeout 90000",
    "test:integration": "bun test tests/per-backend.test.ts --timeout 90000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260629.1",
    "bun-types": "^1.3.14"
  }
}
